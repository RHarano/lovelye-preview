# lovelye — static site
DirectoryIndex index.html
Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# Old WordPress URLs -> new pages (keep inbound links / SEO working)
RewriteRule ^order/?$        /order.html       [R=301,L]
RewriteRule ^sandart/?$      /order.html       [R=301,L]
RewriteRule ^artist/?$       /artist.html      [R=301,L]
RewriteRule ^therapist/?$    /therapist.html   [R=301,L]
RewriteRule ^salon/?$        /salon.html   [R=301,L]
RewriteRule ^shield-?art/?$  /#shieldart   [R=301,L,NE]
</IfModule>

# Long cache for static assets, no-cache for HTML
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 7 days"
ExpiresByType application/javascript "access plus 7 days"
ExpiresByType image/jpeg "access plus 30 days"
ExpiresByType image/png "access plus 30 days"
ExpiresByType text/html "access plus 0 seconds"
</IfModule>
